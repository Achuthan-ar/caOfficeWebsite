PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/ca_office
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m

# SMTP Configuration (Nodemailer)
# If left blank, the application will automatically fall back to Ethereal Email test accounts
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=support@caoffice.com

# Cloudinary Configuration
# If left blank, the application will automatically fall back to local disk storage in backend/uploads/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
